{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "enabledManagers": [],
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["^\\.github/workflows/.*\\.yml$"],
      "matchStrings": ["(?<depName>[a-z][a-z0-9-]+)@(?<currentValue>\\d+\\.\\d+\\.\\d+)"],
      "datasourceTemplate": "crate"
    }
  ]
}
